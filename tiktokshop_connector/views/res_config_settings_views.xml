<odoo>

    <record id="view_res_config_settings_tiktok" model="ir.ui.view">
        <field name="name">res.config.settings.tiktok</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//form" position="inside">
                <group string="TikTok Shop Connector">
                    <field name="tiktok_app_key"/>
                    <field name="tiktok_app_secret"/>
                    <field name="tiktok_access_token"/>
                </group>
            </xpath>

        </field>
    </record>

</odoo>